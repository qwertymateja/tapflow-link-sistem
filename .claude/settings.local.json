{
  "permissions": {
    "allow": [
      "PowerShell(Start-Sleep -Seconds 8; $null)",
      "PowerShell(Invoke-WebRequest -Uri \"http://localhost:3000\" -UseBasicParsing | Select-Object -ExpandProperty StatusCode)",
      "PowerShell(Invoke-WebRequest -Uri \"http://localhost:3000/admin\" -UseBasicParsing | Select-Object -ExpandProperty StatusCode)",
      "PowerShell(Invoke-WebRequest -Uri \"http://localhost:3000/api/profile\" -UseBasicParsing | Select-Object -ExpandProperty Content)",
      "PowerShell(New-Item *)",
      "PowerShell(Get-ChildItem -Path C:\\\\moj-linktree -Force | Where-Object { $_.Name -match '^\\\\.' -or $_.Name -match 'env' } | Select-Object -ExpandProperty Name)",
      "Bash(npx tsc *)",
      "Bash(npx next *)"
    ]
  }
}
